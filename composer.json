{
    "type": "think-admin-plugin",
    "name": "hlw2326/think-plugin-collect",
    "homepage": "https://www.hlw2326.com",
    "description": "HLW,Collect",
    "license": "MIT",
    "authors": [
        {
            "name": "hlw2326",
            "email": "1608626143@qq.com"
        }
    ],
    "require": {
        "php": ">8.2",
        "ext-json": "*",
        "ext-curl": "*",
        "php-curl-class/php-curl-class": "^9.8"
    },
    "autoload": {
        "psr-4": {
            "plugin\\collect\\": "src"
        }
    },
    "extra": {
        "think": {
            "services": [
                "plugin\\collect\\Service"
            ]
        },
        "plugin": {
            "copy": {
                "stc/database": "database/migrations"
            }
        },
        "config": {
            "type": "module",
            "name": "采集接口",
            "document": "https://www.hlw2326.com",
            "description": "多平台采集管理插件",
            "license": []
        }
    }
}
